<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Erreur | Gracias Group</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('./partials/navbar') %>

  <section style="background: linear-gradient(135deg, var(--dark-bg) 0%, #1e3a8a 100%); color: white; min-height: 80vh; display: flex; align-items: center; justify-content: center; padding: 2rem;">
    <div style="text-align: center;">
      <div style="font-size: 5rem; margin-bottom: 1rem; color: #ef4444;">
        <i class="fas fa-exclamation-triangle"></i>
      </div>
      <h1 style="font-size: 3rem; margin-bottom: 1rem;">Erreur</h1>
      <p style="font-size: 1.2rem; margin-bottom: 2rem; color: #cbd5e1; max-width: 500px;">
        <%= message || 'Une erreur s\'est produite de notre côté. Veuillez réessayer plus tard.' %>
      </p>
      <a href="/" class="btn btn-primary">
        <i class="fas fa-home"></i> Retour à l'Accueil
      </a>
    </div>
  </section>

  <%- include('./partials/footer') %>
</body>
</html>
